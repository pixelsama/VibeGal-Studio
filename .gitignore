# ── 依赖 ──────────────────────────────
node_modules/
.pnpm-store/

# ── 构建产物 ──────────────────────────
# Vite / TypeScript 前端产物
dist/
*.tsbuildinfo
.tsbuildinfo

# ── Tauri / Rust ─────────────────────
# Rust 编译产物（很大，绝不提交）
src-tauri/target/
**/target/

# Tauri 自动生成的 schema / capability 缓存
src-tauri/gen/

# esbuild.wasm 二进制（13MB，由 postinstall 从 npm 包拷贝，不提交）
packages/studio/public/esbuild.wasm
packages/studio/src-tauri/resources/exporter/*
!packages/studio/src-tauri/resources/exporter/README.md
packages/studio/src-tauri/resources/player/*
!packages/studio/src-tauri/resources/player/README.md

# ── 日志 / 临时文件 ──────────────────
*.log
npm-debug.log*
pnpm-debug.log*

# ── 编辑器 / 系统 ────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── 环境 / 密钥 ──────────────────────
.env
.env.*
!.env.example
