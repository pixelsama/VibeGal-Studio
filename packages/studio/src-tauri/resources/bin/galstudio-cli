#!/usr/bin/env bash

app_realpath() {
	SOURCE="$1"
	while [ -h "$SOURCE" ]; do
		DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
		SOURCE="$(readlink "$SOURCE")"
		[[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
	done
	SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
	echo "${SOURCE_DIR%%${SOURCE_DIR#*.app}}"
}

APP_PATH="$(app_realpath "${BASH_SOURCE[0]}")"
if [ -z "$APP_PATH" ]; then
	echo "Unable to determine GalStudio app path from symlink: ${BASH_SOURCE[0]}" >&2
	exit 1
fi

CLI="$APP_PATH/Contents/MacOS/galstudio-cli"
if [ ! -x "$CLI" ]; then
	echo "GalStudio CLI sidecar not found or not executable: $CLI" >&2
	exit 1
fi

exec "$CLI" "$@"
