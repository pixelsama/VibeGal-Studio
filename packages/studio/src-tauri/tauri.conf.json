{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VibeGal-Studio",
  "version": "0.1.0-alpha.1",
  "identifier": "com.vibegal.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && node scripts/prepare-web-exporter.mjs",
    "beforeBundleCommand": "node scripts/prepare-cli-sidecar.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "VibeGal-Studio",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": []
      },
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost blob: data: https:; media-src 'self' asset: http://asset.localhost blob: data: https:; connect-src 'self' ipc: http://ipc.localhost asset: http://asset.localhost https://www.unpkg.com; worker-src 'self' blob:; wasm-unsafe-eval 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "pixelsama",
    "homepage": "https://github.com/pixelsama/VibeGal-Studio",
    "copyright": "Copyright (c) 2026 pixelsama",
    "shortDescription": "Graph-first galgame studio and live preview editor",
    "longDescription": "Create, validate, preview, and export graph-first galgame projects with project-local renderers.",
    "licenseFile": "../../../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/default-renderer/*": "resources/default-renderer/",
      "resources/exporter/": "exporter/",
      "resources/player/": "player/",
      "resources/bin/vibegal-cli": "bin/vibegal-cli"
    },
    "externalBin": [
      "binaries/vibegal-cli"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
