          "name",
          "sprites"
        ]
      }
    },
    "backgrounds": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "audio": {
      "default": {
        "bgm": {},
        "sfx": {},
        "voice": {}
      },
      "type": "object",
      "properties": {
        "bgm": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
