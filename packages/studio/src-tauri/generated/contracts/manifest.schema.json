              "path": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string"
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "thumbnail": {
                "type": "string"
              },
              "poster": {
