{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": {
      "type": "number",
      "const": 1
    },
    "variables": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^(?!system\\.)(?:[A-Za-z_][A-Za-z0-9_]*)(?:\\.[A-Za-z_][A-Za-z0-9_]*)*$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "string",
              "number",
              "boolean"
            ]
          },
          "default": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "nullable": {
            "default": false,
            "type": "boolean"
          },
          "scope": {
            "default": "run",
            "type": "string",
            "enum": [
              "run",
              "global"
            ]
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "type",
          "default"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "version"
  ],
  "additionalProperties": false
}
